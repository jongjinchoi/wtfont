Output assets/screenshots/browse.gif

Require wtfont

Set Shell "zsh"
Set FontSize 18
Set Width 1200
Set Height 700
Set Padding 20
Env PROMPT_EOL_MARK ""

Type "wtfont browse serif --limit 10"
Sleep 500ms
Enter
Sleep 2s
Down
Sleep 300ms
Down
Sleep 500ms
Screenshot assets/screenshots/browse.png
Sleep 1s
Type "q"
Sleep 300ms
