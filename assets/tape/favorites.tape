Output assets/screenshots/favorites.gif

Require wtfont

Set Shell "zsh"
Set FontSize 18
Set Width 1200
Set Height 700
Set Padding 20
Env PROMPT_EOL_MARK ""

Type "wtfont favorites list"
Sleep 500ms
Enter
Sleep 2s
Down
Sleep 500ms
Screenshot assets/screenshots/favorites.png
Sleep 1s
Type "q"
Sleep 300ms
