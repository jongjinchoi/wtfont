{
  "name": "wtfont",
  "version": "0.1.0",
  "description": "Identify web fonts and find free Google Fonts alternatives from your terminal.",
  "type": "module",
  "main": "dist/npm/index.js",
  "bin": {
    "wtfont": "./dist/npm/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jongjinchoi/wtfont.git"
  },
  "keywords": [
    "font",
    "web-font",
    "google-fonts",
    "cli",
    "terminal",
    "tui",
    "mcp",
    "font-identifier"
  ],
  "files": [
    "dist/npm",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:npm": "bun run build-npm.ts",
    "prepack": "bun run build-npm.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "update-db": "bun run scripts/generate-fonts-db.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "commander": "^14.0.0",
    "css-tree": "^3.1.0",
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "playwright-core": "^1.58.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/css-tree": "^2",
    "@types/node": "^20",
    "@types/react": "^19",
    "playwright-core": "^1.58.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
